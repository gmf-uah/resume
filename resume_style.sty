\urlstyle{same}

\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

% GPA box definition
\newtcolorbox{gpabox}{
  enhanced,
  colback=white,
  boxrule=0pt,                 % invisible borders
  arc=3mm,                     % rounded corners
  left=2mm, right=2mm,
  top=1mm, bottom=1mm,
  frame hidden,                % hide the box outline
  borderline={0pt}{0pt}{},     % no visible sides
  interior style={
    left color=green!15,
    right color=green!5,
  },
}

